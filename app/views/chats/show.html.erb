<div class="container mt-5">
  <%= link_to "← Back to character",
      character_path(@chat.character),
      class: "btn btn-dark" %>

  <div class="card shadow-sm mt-3 p-4">
    <h1>Chat with <%= @chat.character.name %></h1>

    <div id="messages">
      <% if @chat.messages.any? %>
        <% @chat.messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>
      <% else %>
        <p id="empty_messages">No messages yet.</p>
      <% end %>
    </div>

    <%= render "messages/form", chat: @chat, message: @message %>
  </div>
</div>
