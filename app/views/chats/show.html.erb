<div class="container mt-5">
  <%= link_to "← Back to character",
      character_path(@chat.character),
      class: "btn btn-dark" %>

  <div class="card shadow-sm mt-3 p-4">
    <h1>Chat with <%= @chat.character.name %></h1>

    <% if @chat.messages.any? %>
      <% @chat.messages.each do |message| %>
        <p>
          <strong><%= message.role %>:</strong>
          <%= message.content %>
        </p>
      <% end %>
    <% else %>
      <p>No messages yet.</p>
    <% end %>

    <div class="mt-4">
      <%= simple_form_for [@chat, @message] do |f| %>
        <%= f.input :content,
            label: "Ask a question",
            required: true,
            placeholder: "Ask something about this character..." %>
        <%= f.button :submit, "Send", class: "btn btn-dark" %>
      <% end %>
    </div>
  </div>
</div>
