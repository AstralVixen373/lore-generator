<section class="auth-page">
  <div class="auth-shell">
    <%= render "devise/shared/auth_navbar" %>

    <div class="auth-content">
      <section class="auth-card" aria-labelledby="auth-title">
        <p class="auth-kicker">REJOINDRE L'AVENTURE</p>
        <h1 id="auth-title">Créer un compte</h1>

        <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
          <%= f.error_notification %>

          <div class="auth-form-fields">
            <%= f.input :email,
                        label: "Adresse email",
                        required: true,
                        autofocus: true,
                        placeholder: "Entrez votre adresse email",
                        input_html: { autocomplete: "email" } %>

            <%= f.input :password,
                        label: "Mot de passe",
                        required: true,
                        placeholder: "Choisissez un mot de passe",
                        hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                        input_html: { autocomplete: "new-password" } %>

            <%= f.input :password_confirmation,
                        label: "Confirmation du mot de passe",
                        required: true,
                        placeholder: "Confirmez votre mot de passe",
                        input_html: { autocomplete: "new-password" } %>
          </div>

          <div class="auth-actions">
            <%= f.button :submit, "Créer mon compte", class: "auth-submit" %>
          </div>
        <% end %>

        <%= render "devise/shared/links" %>
      </section>
    </div>
  </div>
</section>
