<section class="auth-page">
  <div class="auth-shell">
    <%= render "devise/shared/auth_navbar" %>

    <div class="auth-content">
      <section class="auth-card" aria-labelledby="auth-title">
        <p class="auth-kicker">DÉVERROUILLER LE COMPTE</p>
        <h1 id="auth-title">Renvoyer les instructions</h1>

        <%= simple_form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "auth-form" }) do |f| %>
          <%= f.error_notification %>
          <%= f.full_error :unlock_token %>

          <div class="auth-form-fields">
            <%= f.input :email,
                        label: "Adresse email",
                        required: true,
                        autofocus: true,
                        placeholder: "Entrez votre adresse email",
                        input_html: { autocomplete: "email" } %>
          </div>

          <div class="auth-actions">
            <%= f.button :submit, "Renvoyer les instructions", class: "auth-submit" %>
          </div>
        <% end %>

        <%= render "devise/shared/links" %>
      </section>
    </div>
  </div>
</section>
