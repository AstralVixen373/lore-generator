<div class="container mt-5">
  <%= link_to "← Back",
  characters_path,
  class: "btn btn-dark" %>
  
  <div class="card shadow-sm mt-3 p-4">
    <%= turbo_stream_from "character_#{@character.id}" %>
    
    <h1><%= @character.name %></h1>

    <div class="d-flex justify-content-center">
      <%= render "image", character: @character %>
    </div>

    <div class="character-info mt-5">
      <p>
        <strong>Race:</strong>
        <%= @character.race %>
      </p>

      <p>
        <strong>Role:</strong>
        <%= @character.role %>
      </p>

      <p>
        <strong>Gender:</strong>
        <%= @character.gender %>
      </p>

      <p>
        <strong>Personality:</strong>
        <%= @character.personality %>
      </p>

        <% if @character.backstory.present? %>
        <p><strong>Backstory: </strong><%= @character.backstory %></p>
        <% end %>

      <hr>

      <%= button_to "Start Chat",
          character_chats_path(@character),
          class: "btn btn-dark mt-3" %>
    </div>

    <hr>

    <h2>Chats</h2>

    <% if @chats.any? %>
      <ul>
        <% @chats.each do |chat| %>
          <li class="d-flex align-items-center gap-2 mb-2">
            <% first_user_message = chat.messages.where(role: "user").order(:created_at).first %>
            <%= link_to first_user_message&.content.presence || "New chat",
                chat_path(chat) %>
            <span class="text-muted">
              <%= chat.created_at.strftime("%d/%m/%Y %H:%M") %>
            </span>
            <%= button_to "Delete",
                chat_path(chat),
                method: :delete,
                class: "btn btn-sm btn-outline-danger" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>No chats yet.</p>
    <% end %>
  </div>
</div>
