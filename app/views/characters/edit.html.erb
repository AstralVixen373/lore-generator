<section class="character-edit-page">
  <div class="character-edit-overlay">
    <header class="home-navbar character-edit-navbar">
      <%= link_to root_path, class: "home-brand", aria: { label: "Retour à l'accueil" } do %>
        <%= image_tag "logo-lore.png", class: "home-brand-logo", alt: "AI Lore Generator" %>
        <span class="home-brand-name">AI Lore <span>Generator</span></span>
      <% end %>

      <div class="home-navbar-right">
        <% if user_signed_in? %>
          <div class="dropdown home-profile-menu">
            <button class="home-avatar" id="characterEditNavbarDropdown" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Ouvrir le menu utilisateur">
              <% if current_user.avatar_url.present? %>
                <%= image_tag current_user.avatar_url,
                    class: "home-avatar-image",
                    alt: current_user.email,
                    referrerpolicy: "no-referrer" %>
              <% else %>
                <% profile_name = current_user.respond_to?(:name) ? current_user.name.to_s.strip : "" %>
                <% initials = if profile_name.present?
                  profile_name.split.map { |part| part.first }.join.first(2).upcase
                else
                  current_user.email.to_s.first.to_s.upcase
                end %>
                <span><%= initials %></span>
              <% end %>
            </button>
            <div class="dropdown-menu dropdown-menu-end home-dropdown-menu" aria-labelledby="characterEditNavbarDropdown">
              <%= link_to "Déconnexion", destroy_user_session_path, data: { turbo_method: :delete }, class: "dropdown-item home-dropdown-item" %>
            </div>
          </div>
        <% else %>
          <%= link_to "Connexion", new_user_session_path, class: "home-login-link" %>
        <% end %>
      </div>
    </header>

    <main class="character-edit-shell">
      <section class="character-edit-panel">
        <%= link_to character_path(@character), class: "character-edit-back" do %>
          <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
          <span>Retour au personnage</span>
        <% end %>

        <div class="character-edit-heading">
          <span class="character-edit-title-icon"><i class="fa-solid fa-feather-pointed" aria-hidden="true"></i></span>
          <h1>Éditeur de personnage</h1>
        </div>

        <%= simple_form_for @character, html: { class: "character-edit-form" } do |f| %>
          <div class="character-edit-field">
            <span class="character-edit-field-icon"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i></span>
            <%= f.input :race,
              label: "Race",
              collection: [["Humain", "Human"], ["Elfe", "Elf"], ["Nain", "Dwarf"], ["Orc", "Orc"], ["Demi-elfe", "Half-elf"], ["Draconien", "Draconians"]],
              prompt: "Choisissez une race" %>
          </div>

          <div class="character-edit-field">
            <span class="character-edit-field-icon"><i class="fa-solid fa-wand-sparkles" aria-hidden="true"></i></span>
            <%= f.input :role,
              label: "Rôle",
              collection: [["Voleur", "Thief"], ["Guerrier", "Warrior"], ["Mage", "Spellcaster"], ["Rôdeur", "Ranger"], ["Clerc", "Cleric"], ["Barde", "Bard"]],
              prompt: "Choisissez un rôle" %>
          </div>

          <div class="character-edit-field">
            <span class="character-edit-field-icon"><i class="fa-solid fa-mars-and-venus" aria-hidden="true"></i></span>
            <%= f.input :gender,
              label: "Genre",
              collection: [["Homme", "Male"], ["Femme", "Female"], ["Non-binaire", "Non-binary"], ["Autre", "Other"]],
              prompt: "Choisissez un genre" %>
          </div>

          <div class="character-edit-field">
            <span class="character-edit-field-icon"><i class="fa-regular fa-gem" aria-hidden="true"></i></span>
            <%= f.input :personality,
              label: "Personnalité",
              collection: [["Froid, rusé et indépendant", "Cold, cunning & independant"], ["Brave et loyal", "Brave & loyal"], ["Mystérieux", "Mysterious"], ["Chaotique", "Chaotic"], ["Sage", "Wise"]],
              prompt: "Choisissez une personnalité" %>
          </div>

          <div class="character-edit-field">
            <span class="character-edit-field-icon"><i class="fa-regular fa-user" aria-hidden="true"></i></span>
            <%= f.input :name,
              label: "Nom",
              placeholder: "Nom du personnage" %>
          </div>

          <div class="character-edit-field character-edit-field-textarea">
            <span class="character-edit-field-icon"><i class="fa-solid fa-book-open" aria-hidden="true"></i></span>
            <%= f.input :history,
              label: "Personnalisation avancée",
              as: :text,
              input_html: { rows: 5 },
              placeholder: "Décrivez son histoire, ses secrets, ses objectifs ou ses détails visuels" %>
          </div>

          <div class="character-edit-actions">
            <%= f.button :submit, "Mettre à jour le personnage", class: "character-edit-submit" %>
          </div>
        <% end %>
      </section>
    </main>
  </div>
</section>
