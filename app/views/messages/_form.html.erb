<div id="new_message_container" class="mt-4">
  <%= simple_form_for [chat, message] do |f| %>
    <%= f.input :content,
        label: "Ask a question",
        required: true,
        placeholder: "Ask something about this character..." %>
    <%= f.button :submit, "Send", class: "btn btn-dark" %>
  <% end %>
</div>
