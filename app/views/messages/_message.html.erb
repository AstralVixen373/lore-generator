<article class="chat-message chat-message-<%= message.role %>">
  <div class="chat-message-header">
    <strong>
      <% if message.role == "user" %>
        Vous
      <% else %>
        <%= message.chat.character.name.presence || "Personnage" %>
      <% end %>
    </strong>
    <time datetime="<%= message.created_at.iso8601 %>"><%= message.created_at.strftime("%H:%M") %></time>
  </div>
  <p><%= message.content %></p>
</article>
